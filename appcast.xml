        <item>
            <title>Version 0.3.1</title>
            <pubDate>Wed, 08 Jul 2026 18:41:08 +0000</pubDate>
            <sparkle:version>0.3.1</sparkle:version>
            <sparkle:shortVersionString>0.3.1</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <ul>
                    <li>Find in page: Cmd+F highlights every match with an N-of-M count; Cmd+G and Cmd+Shift+G step through matches.</li>
                    <li>Automatic updates: the browser now checks for signed updates on launch and via Tools &gt; Check for Updates.</li>
                    <li>Cmd+click opens links in a background tab.</li>
                </ul>
            ]]></description>
            <enclosure
              url="https://github.com/dep/synapse-browser/releases/download/0.3.1/Synapse.Browser-0.3.1-universal.dmg"
